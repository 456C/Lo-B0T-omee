# Lo Bot Tomee - Discord Embed Fixer Bot
# Copy this file to .env and fill in the values

# Your bot token from Discord Developer Portal (https://discord.com/developers/applications)
# NEVER commit your real token!
DISCORD_TOKEN=your_bot_token_here

# The Discord User ID of the user whose avatar the bot should copy.
# Tag: @you_look_like_you_love_me
# How to get the ID:
# 1. Enable Developer Mode in Discord (User Settings > Advanced > Developer Mode)
# 2. Right-click the user in a shared server -> Copy User ID
# The bot must be able to fetch this user (usually works if you have the ID)
TARGET_USER_ID=123456789012345678

# Provided info:
# Application ID: 1520844876303044659
# (Public ID / Public Key may be used if adding slash commands later)
# BOT_PUBLIC_KEY=3a4b778dfc6f9dbe96d1df382d3a29aa0d730e8305eab242c394193283f6f4be

# Optional: Customize bot name (limited by Discord rate limits)
# BOT_NAME=Lo Bot Tomee
